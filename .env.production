# PostgreSQL 配置
POSTGRES_DB=stream2graph
POSTGRES_USER=stream2graph
POSTGRES_PASSWORD=请修改为强密码
POSTGRES_PORT=5432

# API 配置
API_PORT=8000
DATABASE_URL=postgresql+psycopg://stream2graph:请修改为强密码@postgres:5432/stream2graph

# 会话密钥（必须修改！使用 openssl rand -hex 32 生成）
S2G_SESSION_SECRET=请修改为随机字符串

# 管理员账号
S2G_ADMIN_USERNAME=admin
S2G_ADMIN_PASSWORD=请修改为强密码
S2G_ADMIN_DISPLAY_NAME=Stream2Graph Admin

# CORS 配置（修改为你的域名）
S2G_CORS_ORIGINS=http://your-domain.com,https://your-domain.com
S2G_COOKIE_SECURE=true
S2G_COOKIE_SAMESITE=lax
S2G_COOKIE_DOMAIN=

# TLS 配置
S2G_TLS_VERIFY=true
S2G_CA_BUNDLE=

# 数据集版本
S2G_DEFAULT_DATASET_VERSION=release_v7_kimi_k25_fullregen_strict_20260313

# LLM 配置（根据需要修改）
S2G_LLM_PROFILES_JSON=[{"id":"openai-default","label":"OpenAI Compatible LLM","provider_kind":"openai_compatible","endpoint":"https://api.openai.com/v1/chat/completions","api_key_env":"OPENAI_API_KEY","models":["gpt-4o-mini","gpt-4o"],"default_model":"gpt-4o-mini"}]

# STT 配置（根据需要修改）
S2G_STT_PROFILES_JSON=[{"id":"openai-stt","label":"OpenAI Compatible STT","provider_kind":"openai_compatible","endpoint":"https://api.openai.com/v1/audio/transcriptions","api_key_env":"OPENAI_API_KEY","models":["whisper-1"],"default_model":"whisper-1"}]

# Web 配置
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://your-domain.com/api
NEXT_PUBLIC_AUDIO_HELPER_BASE_URL=http://your-domain.com/audio

# Audio Helper 配置
AUDIO_HELPER_PORT=8765
S2G_AUDIO_HELPER_CORS_ORIGINS=http://your-domain.com,https://your-domain.com
S2G_HELPER_TRANSCRIBER=faster_whisper
S2G_HELPER_MODEL_SIZE=small
S2G_HELPER_LANGUAGE=zh
S2G_HELPER_DEVICE=cpu
S2G_HELPER_COMPUTE_TYPE=int8
