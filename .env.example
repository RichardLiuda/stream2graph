DATABASE_URL=postgresql+psycopg://stream2graph:stream2graph@127.0.0.1:5432/stream2graph
S2G_SESSION_SECRET=change-me
S2G_ADMIN_USERNAME=admin
S2G_ADMIN_PASSWORD=admin123456
S2G_ADMIN_DISPLAY_NAME="Stream2Graph Admin"
S2G_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# 留空则使用内置规则（RFC1918 局域网 + ngrok / trycloudflare 等）；仅当需完全自定义时再写正则
S2G_CORS_ORIGIN_REGEX=
S2G_COOKIE_SECURE=false
S2G_COOKIE_SAMESITE=lax
S2G_COOKIE_DOMAIN=
S2G_TLS_VERIFY=true
S2G_CA_BUNDLE=
S2G_INLINE_WORKER=false
S2G_INLINE_WORKER_POLL_INTERVAL=2.0
S2G_DEFAULT_DATASET_VERSION=release_v7_kimi_k25_fullregen_strict_20260313
S2G_MERMAID_COMPILE_COMMAND=
S2G_LLM_PROFILES_JSON=[{"id":"openai-default","label":"OpenAI Compatible LLM","provider_kind":"openai_compatible","endpoint":"https://api.openai.com/v1/chat/completions","api_key_env":"OPENAI_API_KEY","models":["gpt-4.1-mini","gpt-4.1"],"default_model":"gpt-4.1-mini"}]
S2G_STT_PROFILES_JSON=[{"id":"openai-stt","label":"OpenAI Compatible STT","provider_kind":"openai_compatible","endpoint":"https://api.openai.com/v1/audio/transcriptions","api_key_env":"OPENAI_API_KEY","models":["gpt-4o-mini-transcribe","whisper-1"],"default_model":"gpt-4o-mini-transcribe"}]
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# 浏览器默认走 Next 同源 /api/* 转发（见 apps/web/app/api/[...path]/route.ts），无需直连 :8000。仅当需要浏览器直连 API 时设为 0
# NEXT_PUBLIC_API_BROWSER_PROXY=0
# Next 服务端 API 代理配置。优先用 API_PROXY_TARGET；需要更灵活切换时改下面这些变量即可，无需改代码。
API_PROXY_TARGET=http://127.0.0.1:8000
S2G_API_PROXY_CANDIDATES=http://127.0.0.1:8000
S2G_API_SERVICE_HOST=api
S2G_API_SERVICE_PORT=8000
# S2G_API_SERVICE_URL=http://api:8000
NEXT_PUBLIC_AUDIO_HELPER_BASE_URL=http://127.0.0.1:8765
S2G_AUDIO_HELPER_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,https://stream.richardliuda.top

# 局域网访问示例（按需启用）
# NEXT_PUBLIC_API_BASE_URL=http://192.168.1.10:8000
# S2G_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://192.168.1.10:3000
# S2G_CORS_ORIGIN_REGEX=^https?://(192\.168\.\d{1,3}\.\d{1,3}|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|172\.(1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3})(:\d+)?$
# S2G_AUDIO_HELPER_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://192.168.1.10:3000
S2G_HELPER_TRANSCRIBER=faster_whisper
S2G_HELPER_MODEL_SIZE=small
S2G_HELPER_LANGUAGE=zh
S2G_HELPER_DEVICE=cpu
S2G_HELPER_COMPUTE_TYPE=int8
