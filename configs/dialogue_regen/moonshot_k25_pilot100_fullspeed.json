{
  "title": "Moonshot kimi-k2.5 100-sample full-speed pilot",
  "output_dir": "reports/dialogue_regen/runs/moonshot_k25_pilot100_fullspeed/suite",
  "steps": {
    "generation": {
      "provider": "moonshot_chat_completions",
      "provider_name": "moonshot_chat_completions",
      "model": "kimi-k2.5",
      "endpoint": "https://api.moonshot.cn/v1/chat/completions",
      "api_key_env": "MOONSHOT_API_KEY",
      "source_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311",
      "split_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311/splits",
      "split": "validation",
      "target_language": "zh-CN",
      "max_samples": 100,
      "temperature": 0.6,
      "max_tokens": 4096,
      "timeout_sec": 180,
      "max_retries": 5,
      "retry_backoff_sec": 3.0,
      "request_interval_sec": 0.0,
      "provider_rate_tier": "tier1",
      "max_concurrency": 50,
      "requests_per_minute": 200,
      "extra_body": {
        "thinking": {
          "type": "disabled"
        }
      },
      "output_jsonl": "reports/dialogue_regen/runs/moonshot_k25_pilot100_fullspeed/generated.jsonl"
    },
    "metrics": {
      "input_jsonl": "reports/dialogue_regen/runs/moonshot_k25_pilot100_fullspeed/generated.jsonl",
      "output_dir": "reports/dialogue_regen/runs/moonshot_k25_pilot100_fullspeed/metrics"
    },
    "report": {
      "summary_json": "reports/dialogue_regen/runs/moonshot_k25_pilot100_fullspeed/metrics/summary.json",
      "output_markdown": "reports/dialogue_regen/runs/moonshot_k25_pilot100_fullspeed/report.md"
    }
  }
}
