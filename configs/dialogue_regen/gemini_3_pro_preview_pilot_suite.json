{
  "title": "Gemini 3 Pro Preview dialogue regeneration pilot",
  "output_dir": "reports/dialogue_regen/runs/gemini_3_pro_preview_pilot/suite",
  "steps": {
    "generation": {
      "provider": "google_generate_content",
      "model": "gemini-3-pro-preview",
      "api_key_env": "GOOGLE_API_KEY",
      "source_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311",
      "split_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311/splits",
      "split": "validation",
      "target_language": "zh-CN",
      "max_samples": 12,
      "temperature": 0.2,
      "max_output_tokens": 4096,
      "thinking_budget": 1024,
      "timeout_sec": 180,
      "max_retries": 5,
      "retry_backoff_sec": 3.0,
      "request_interval_sec": 1.0,
      "response_mime_type": "application/json",
      "response_json_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sample_id",
          "dialogue_language",
          "cscw_dialogue"
        ],
        "properties": {
          "sample_id": {
            "type": "string"
          },
          "dialogue_language": {
            "type": "string"
          },
          "cscw_dialogue": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "turn_id",
                "role",
                "action_type",
                "utterance",
                "elements_involved",
                "is_repair"
              ],
              "properties": {
                "turn_id": {
                  "type": "integer"
                },
                "role": {
                  "type": "string",
                  "enum": [
                    "Domain_Expert",
                    "Diagram_Editor"
                  ]
                },
                "action_type": {
                  "type": "string",
                  "enum": [
                    "propose",
                    "clarify",
                    "confirm",
                    "execute",
                    "repair"
                  ]
                },
                "utterance": {
                  "type": "string"
                },
                "elements_involved": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "is_repair": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "output_jsonl": "reports/dialogue_regen/runs/gemini_3_pro_preview_pilot/generated.jsonl"
    },
    "metrics": {
      "input_jsonl": "reports/dialogue_regen/runs/gemini_3_pro_preview_pilot/generated.jsonl",
      "output_dir": "reports/dialogue_regen/runs/gemini_3_pro_preview_pilot/metrics"
    },
    "report": {
      "summary_json": "reports/dialogue_regen/runs/gemini_3_pro_preview_pilot/metrics/summary.json",
      "output_markdown": "reports/dialogue_regen/runs/gemini_3_pro_preview_pilot/report.md"
    }
  }
}
