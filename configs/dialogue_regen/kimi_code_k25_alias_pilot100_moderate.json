{
  "title": "Kimi Code kimi-k2.5 alias 100-sample moderate-speed pilot",
  "output_dir": "reports/dialogue_regen/runs/kimi_code_k25_alias_pilot100_moderate/suite",
  "steps": {
    "generation": {
      "provider": "anthropic_messages",
      "provider_name": "kimi_code_messages",
      "model": "kimi-k2.5",
      "endpoint": "https://api.kimi.com/coding/v1/messages",
      "api_key_env": "KIMI_CODE_API_KEY",
      "anthropic_version": "2023-06-01",
      "source_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311",
      "split_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311/splits",
      "split": "validation",
      "target_language": "zh-CN",
      "max_samples": 100,
      "temperature": 0.6,
      "max_tokens": 4096,
      "timeout_sec": 180,
      "max_retries": 6,
      "retry_backoff_sec": 4.0,
      "request_interval_sec": 0.0,
      "max_concurrency": 10,
      "requests_per_minute": 60,
      "output_jsonl": "reports/dialogue_regen/runs/kimi_code_k25_alias_pilot100_moderate/generated.jsonl"
    },
    "metrics": {
      "input_jsonl": "reports/dialogue_regen/runs/kimi_code_k25_alias_pilot100_moderate/generated.jsonl",
      "output_dir": "reports/dialogue_regen/runs/kimi_code_k25_alias_pilot100_moderate/metrics"
    },
    "report": {
      "summary_json": "reports/dialogue_regen/runs/kimi_code_k25_alias_pilot100_moderate/metrics/summary.json",
      "output_markdown": "reports/dialogue_regen/runs/kimi_code_k25_alias_pilot100_moderate/report.md"
    }
  }
}
