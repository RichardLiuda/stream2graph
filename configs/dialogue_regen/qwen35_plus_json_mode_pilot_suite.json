{
  "title": "Qwen3.5-Plus dialogue regeneration pilot (JSON mode)",
  "output_dir": "reports/dialogue_regen/runs/qwen35_plus_json_mode_pilot/suite",
  "steps": {
    "generation": {
      "provider": "dashscope_chat_completions",
      "provider_name": "dashscope_chat_completions",
      "model": "qwen3.5-plus",
      "endpoint": "https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions",
      "api_key_env": "DASHSCOPE_API_KEY",
      "source_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311",
      "split_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311/splits",
      "split": "validation",
      "target_language": "zh-CN",
      "max_samples": 12,
      "temperature": 0.2,
      "max_tokens": 4096,
      "timeout_sec": 180,
      "max_retries": 5,
      "retry_backoff_sec": 3.0,
      "request_interval_sec": 1.0,
      "output_jsonl": "reports/dialogue_regen/runs/qwen35_plus_json_mode_pilot/generated.jsonl",
      "extra_body": {
        "response_format": {
          "type": "json_object"
        }
      }
    },
    "metrics": {
      "input_jsonl": "reports/dialogue_regen/runs/qwen35_plus_json_mode_pilot/generated.jsonl",
      "output_dir": "reports/dialogue_regen/runs/qwen35_plus_json_mode_pilot/metrics"
    },
    "report": {
      "summary_json": "reports/dialogue_regen/runs/qwen35_plus_json_mode_pilot/metrics/summary.json",
      "output_markdown": "reports/dialogue_regen/runs/qwen35_plus_json_mode_pilot/report.md"
    }
  }
}
