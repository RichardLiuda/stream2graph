{
  "title": "Kimi K2.5 truncation repair pilot",
  "output_dir": "reports/dialogue_regen/runs/kimi_k25_truncation_repair/suite",
  "steps": {
    "generation": {
      "provider": "moonshot_chat_completions",
      "provider_name": "moonshot_chat_completions",
      "model": "kimi-k2.5",
      "endpoint": "https://api.moonshot.cn/v1/chat/completions",
      "api_key_env": "MOONSHOT_API_KEY",
      "source_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311",
      "split_dir": "versions/v3_2026-02-27_latest_9k_cscw/dataset/stream2graph_dataset/release_v4_20260311/splits",
      "split": "validation",
      "target_language": "zh-CN",
      "sample_ids_file": "artifacts/dialogue_regen/kimi_truncation_fail_ids.json",
      "temperature": 0.6,
      "max_tokens": 8192,
      "timeout_sec": 240,
      "max_retries": 5,
      "retry_backoff_sec": 3.0,
      "request_interval_sec": 0.0,
      "provider_rate_tier": "tier1",
      "max_concurrency": 8,
      "requests_per_minute": 120,
      "output_jsonl": "reports/dialogue_regen/runs/kimi_k25_truncation_repair/generated.jsonl",
      "extra_body": {
        "thinking": {
          "type": "disabled"
        },
        "response_format": {
          "type": "json_object"
        }
      }
    },
    "metrics": {
      "input_jsonl": "reports/dialogue_regen/runs/kimi_k25_truncation_repair/generated.jsonl",
      "output_dir": "reports/dialogue_regen/runs/kimi_k25_truncation_repair/metrics"
    },
    "report": {
      "summary_json": "reports/dialogue_regen/runs/kimi_k25_truncation_repair/metrics/summary.json",
      "output_markdown": "reports/dialogue_regen/runs/kimi_k25_truncation_repair/report.md"
    }
  }
}
